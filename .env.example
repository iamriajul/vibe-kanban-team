# Copy this file to .env before running docker compose.
# Keep .env out of git. All passwords used inside connection URLs should be URL-safe.

# Public hostname that points to this machine. Caddy listens on HTTP_PORT/HTTPS_PORT
# and obtains/renews TLS certificates automatically for real domains.
DOMAIN=vibe-kanban.example.com
SERVER_PUBLIC_BASE_URL=https://vibe-kanban.example.com
HTTP_PORT=80
HTTPS_PORT=443

# Published release image tag. Pin this to a release tag for production rollouts;
# latest follows the most recent stable remote image.
VKT_IMAGE_TAG=latest
REMOTE_IMAGE=ghcr.io/iamriajul/vibe-kanban-team-remote
RELAY_IMAGE=ghcr.io/iamriajul/vibe-kanban-team-relay
POSTGRES_IMAGE=postgres:17-alpine
ELECTRIC_IMAGE=electricsql/electric
ELECTRIC_TAG=1.3.3

# Generate with: openssl rand -base64 48
VIBEKANBAN_REMOTE_JWT_SECRET=replace_with_base64_jwt_secret

# Generate URL-safe values with: openssl rand -hex 24
DB_PASSWORD=replace_with_url_safe_database_password
ELECTRIC_ROLE_PASSWORD=replace_with_url_safe_electric_password

# Authentication: configure at least one OAuth provider, Zoho provider, or the
# bootstrap local auth pair below. Local auth is useful for first self-host setup.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
ZOHO_OAUTH_CLIENT_ID=
ZOHO_OAUTH_CLIENT_SECRET=
# Optional, for non-US Zoho accounts such as https://accounts.zoho.eu
ZOHO_ACCOUNTS_URL=
SELF_HOST_LOCAL_AUTH_EMAIL=
SELF_HOST_LOCAL_AUTH_PASSWORD=

# Optional comma-separated allowlist applied after OAuth/local login.
ALLOWED_EMAIL_DOMAINS=

# Optional Loops email integration.
LOOPS_EMAIL_API_KEY=
LOOPS_INVITE_TEMPLATE_ID=
LOOPS_REVIEW_READY_TEMPLATE_ID=
LOOPS_REVIEW_FAILED_TEMPLATE_ID=

# Optional R2 storage for review uploads and issue attachments.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_REVIEW_ENDPOINT=
R2_REVIEW_BUCKET=
R2_PRESIGN_EXPIRY_SECS=3600

# Optional review/digest/GitHub App integrations.
REVIEW_WORKER_BASE_URL=
REVIEW_DISABLED=false
DIGEST_ENABLED=false
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=
GITHUB_APP_SLUG=

# Optional advanced Electric configuration.
ELECTRIC_PUBLICATION_NAMES=
RUST_LOG=info,remote=info
