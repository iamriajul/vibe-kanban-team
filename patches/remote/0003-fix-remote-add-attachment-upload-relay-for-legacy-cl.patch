 #[derive(Debug, Serialize, Deserialize, TS)]
 #[ts(export)]
 pub struct InitUploadRequest {
@@ -179,29 +184,85 @@ async fn init_upload(
         }));
     }
 
-    let r2 = state.r2().ok_or(RouteError::NotConfigured)?;
+    state.r2().ok_or(RouteError::NotConfigured)?;
     let sanitized_filename = sanitize_filename(&payload.filename);
     let blob_path = format!("attachments/{}/{}_{}", payload.project_id, Uuid::new_v4(), sanitized_filename);
-    let upload = r2.create_upload_url(&blob_path, None).await?;
+
+    let expires_at = Utc::now() + chrono::Duration::minutes(5);
 
     let pending = PendingUploadRepository::create(
         state.pool(),
         payload.project_id,
-        upload.blob_path,
+        blob_path,
         payload.hash.clone(),
-        upload.expires_at,
+        expires_at,
     )
     .await?;
 
+    let upload_url = format!(
