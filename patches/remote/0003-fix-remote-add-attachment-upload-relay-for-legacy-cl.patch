     }
@@ -227,7 +240,7 @@ impl R2Service {
             .content_type(content_type)
             .send()
             .await
-            .map_err(|e| R2Error::Upload(e.to_string()))?;
+            .map_err(|e| R2Error::Upload(format_error_chain(&e)))?;
 
