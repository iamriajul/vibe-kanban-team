+
+        if content_length > MAX_FILE_SIZE {
             return Err(RouteError::FileTooLarge);
         }
 
-        let blob_data = r2.download_blob(blob_path).await?;
+        let download_response = state
+            .http_client
+            .get(&read_url)
+            .send()
+            .await
+            .map_err(|e| RouteError::R2(R2Error::Storage(format!("relay download request failed: {e}"))))?;
+
+        if !download_response.status().is_success() {
+            let status = download_response.status();
+            let body = download_response.text().await.unwrap_or_default();
+            return Err(RouteError::R2(R2Error::Storage(format!(
+                "relay download failed with status {status}: {body}"
+            ))));
+        }
