From ebd385ccae8dad86f35afcd8cdc327fbf207f8fd Mon Sep 17 00:00:00 2001
From: Riajul Islam <riajul@kahf.co>
Date: Mon, 13 Apr 2026 08:31:18 +0000
Subject: [PATCH] fix: add 30s WebSocket ping keepalive to all long-lived WS
 handlers

---
 crates/server/src/routes/approvals.rs         | 10 +++++++
 .../server/src/routes/execution_processes.rs  | 27 +++++++++++++++++++
 crates/server/src/routes/scratch.rs           | 10 +++++++
 crates/server/src/routes/terminal.rs          | 10 ++++++-
 .../server/src/routes/workspaces/streams.rs   | 18 +++++++++++++
 5 files changed, 74 insertions(+), 1 deletion(-)

diff --git a/crates/server/src/routes/approvals.rs b/crates/server/src/routes/approvals.rs
index 5d2d29329..9e8f3dca4 100644
--- a/crates/server/src/routes/approvals.rs
+++ b/crates/server/src/routes/approvals.rs
@@ -1,3 +1,5 @@
+use std::time::Duration;
+
 use axum::{
     Router,
     extract::{State, ws::Message},
@@ -74,6 +76,9 @@ async fn handle_approvals_ws(
     }
     socket.send(LogMsg::Ready.to_ws_message_unchecked()).await?;
 
+    let mut ping_interval = tokio::time::interval(Duration::from_secs(30));
+    ping_interval.tick().await; // skip first immediate tick
+
     loop {
         tokio::select! {
             patch = stream.next() => {
@@ -100,6 +105,11 @@ async fn handle_approvals_ws(
                     }
                 }
             }
+            _ = ping_interval.tick() => {
+                if socket.send(Message::Ping(vec![].into())).await.is_err() {
+                    break;
+                }
+            }
         }
     }
 
