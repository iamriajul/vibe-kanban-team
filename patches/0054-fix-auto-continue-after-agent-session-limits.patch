+    async fn maybe_schedule_session_limit_auto_continue(
+        &self,
+        ctx: &ExecutionContext,
+        exec_id: Uuid,
+    ) -> bool {
+        if !matches!(
+            ctx.execution_process.run_reason,
+            ExecutionProcessRunReason::CodingAgent
+        ) {
+            return false;
+        }
+
+        let executor_config =
+            match ctx
+                .execution_process
+                .executor_action()
+                .ok()
+                .and_then(|action| match &action.typ {
+                    ExecutorActionType::CodingAgentInitialRequest(request) => {
+                        Some(request.executor_config.clone())
+                    }
+                    ExecutorActionType::CodingAgentFollowUpRequest(request) => {
+                        Some(request.executor_config.clone())
+                    }
+                    _ => None,
+                }) {
+                Some(config) => config,
+                None => return false,
+            };
+
+        let plan = {
+            let msg_stores = self.msg_stores.read().await;
+            let Some(msg_store) = msg_stores.get(&exec_id) else {
+                return false;
+            };
+            detect_session_limit_auto_continue(&msg_store.get_history(), Utc::now())
+        };
+
+        let Some(plan) = plan else {
+            return false;
+        };
+
+        let session_id = ctx.session.id;
+        let container = self.clone();
+        let auth_session_id = self.auth_session_for_execution(exec_id).await;
+        tracing::info!(
+            "Scheduling automatic Continue for session {} in {:?}: {}",
+            session_id,
+            plan.delay,
+            plan.reason
+        );
+
+        tokio::spawn(async move {
+            tokio::time::sleep(plan.delay).await;
+
+            let run = async {
+                if container.queued_message_service.has_queued(session_id) {
+                    tracing::info!(
+                        "Skipping automatic Continue for session {} because a queued message exists",
+                        session_id
+                    );
+                    return;
+                }
+
+                if ExecutionProcess::has_running_coding_agent_for_session(
+                    &container.db.pool,
+                    session_id,
+                )
+                .await
+                .unwrap_or(true)
+                {
+                    tracing::info!(
+                        "Skipping automatic Continue for session {} because an agent is running",
+                        session_id
+                    );
+                    return;
+                }
+
+                let processes = match ExecutionProcess::find_by_session_id(
+                    &container.db.pool,
+                    session_id,
+                    false,
+                )
+                .await
+                {
+                    Ok(processes) => processes,
+                    Err(err) => {
+                        tracing::warn!(
+                            "Failed to inspect session {} before automatic Continue: {}",
+                            session_id,
+                            err
+                        );
+                        return;
+                    }
+                };
+
+                if processes.last().map(|process| process.id) != Some(exec_id) {
+                    tracing::info!(
+                        "Skipping automatic Continue for session {} because the session has moved on",
+                        session_id
+                    );
+                    return;
+                }
+
+                let ctx = match ExecutionProcess::load_context(&container.db.pool, exec_id).await {
+                    Ok(ctx) => ctx,
+                    Err(err) => {
+                        tracing::warn!(
+                            "Failed to load execution context for automatic Continue {}: {}",
+                            exec_id,
+                            err
+                        );
+                        return;
+                    }
+                };
+
+                let data = DraftFollowUpData {
+                    message: AUTO_CONTINUE_PROMPT.to_string(),
+                    executor_config,
+                };
+
+                if let Err(err) = container.start_queued_follow_up(&ctx, &data).await {
+                    tracing::error!(
+                        "Failed to start automatic Continue for session {}: {}",
+                        session_id,
+                        err
+                    );
+                }
+            };
+
+            if let Some(auth_session_id) = auth_session_id {
+                container
+                    .auth_context
+                    .run_with_session(auth_session_id, run)
+                    .await;
+            } else {
+                run.await;
+            }
+        });
+
+        true
+    }
