+
+#[derive(Debug, Clone)]
+struct AutoContinuePlan {
+    delay: Duration,
+    reason: String,
+}
+
+fn detect_session_limit_auto_continue(
+    history: &[LogMsg],
+    now: DateTime<Utc>,
+) -> Option<AutoContinuePlan> {
+    let text = history
+        .iter()
+        .filter_map(log_msg_text)
+        .collect::<Vec<_>>()
+        .join("\n");
+    let lower = text.to_lowercase();
+
+    if !looks_like_session_limit(&lower) {
+        return None;
+    }
+
+    if let Some(delay) = parse_relative_delay(&lower) {
+        return bounded_auto_continue_delay(delay).map(|delay| AutoContinuePlan {
+            delay,
+            reason: "relative session-limit reset delay".to_string(),
+        });
+    }
+
+    if let Some(delay) = parse_utc_reset_delay(&lower, now) {
+        return bounded_auto_continue_delay(delay).map(|delay| AutoContinuePlan {
+            delay,
+            reason: "UTC session-limit reset time".to_string(),
+        });
+    }
+
+    tracing::info!("Detected session-limit output but could not parse a reset time");
+    None
+}
+
+fn log_msg_text(msg: &LogMsg) -> Option<String> {
+    match msg {
+        LogMsg::Stdout(value) | LogMsg::Stderr(value) => Some(value.clone()),
+        LogMsg::JsonPatch(patch) => serde_json::to_string(patch).ok(),
+        _ => None,
+    }
+}
+
+fn looks_like_session_limit(value: &str) -> bool {
+    value.contains("hit your session limit")
+        || value.contains("session limit reached")
+        || value.contains("session limit")
+            && (value.contains("reset") || value.contains("try again") || value.contains("retry"))
+        || value.contains("usage limit")
+            && (value.contains("reached") || value.contains("exceeded") || value.contains("reset"))
+        || value.contains("rate limit")
+            && (value.contains("reached")
+                || value.contains("exceeded")
+                || value.contains("try again")
+                || value.contains("retry after"))
+        || value.contains("quota exceeded")
+        || value.contains("resource exhausted")
+}
+
+fn parse_relative_delay(value: &str) -> Option<Duration> {
+    for marker in [
+        "retry after ",
+        "try again in ",
+        "resets in ",
+        "reset in ",
+        "available in ",
+    ] {
+        if let Some(index) = value.find(marker) {
+            let fragment = value[index + marker.len()..]
+                .chars()
+                .take(96)
+                .collect::<String>();
+            if let Some(delay) = parse_duration_fragment(&fragment) {
+                return Some(delay + AUTO_CONTINUE_RESET_BUFFER);
+            }
+        }
+    }
+    None
+}
+
+fn parse_duration_fragment(fragment: &str) -> Option<Duration> {
+    let normalized = fragment
+        .chars()
+        .map(|ch| if ch.is_ascii_alphanumeric() { ch } else { ' ' })
+        .collect::<String>();
+    let tokens = normalized.split_whitespace().collect::<Vec<_>>();
+    let mut seconds = 0u64;
+    let mut index = 0usize;
+
+    while index < tokens.len() {
+        let token = tokens[index];
+        if let Some((amount, unit)) = parse_compact_duration_token(token) {
+            seconds = seconds.saturating_add(duration_unit_seconds(amount, unit)?);
+            index += 1;
+            continue;
+        }
+
+        let amount = match token.parse::<u64>() {
+            Ok(amount) => amount,
+            Err(_) => {
+                if seconds > 0 {
+                    break;
+                }
+                index += 1;
+                continue;
+            }
+        };
+
+        let unit = tokens.get(index + 1).copied().unwrap_or("seconds");
+        seconds = seconds.saturating_add(duration_unit_seconds(amount, unit)?);
+        index += 2;
+    }
+
+    (seconds > 0).then(|| Duration::from_secs(seconds))
+}
+
+fn parse_compact_duration_token(token: &str) -> Option<(u64, &str)> {
+    let split = token
+        .char_indices()
+        .find_map(|(idx, ch)| (!ch.is_ascii_digit()).then_some(idx))?;
+    if split == 0 {
+        return None;
+    }
+    let amount = token[..split].parse::<u64>().ok()?;
+    Some((amount, &token[split..]))
+}
+
+fn duration_unit_seconds(amount: u64, unit: &str) -> Option<u64> {
+    let multiplier = match unit {
+        "s" | "sec" | "secs" | "second" | "seconds" => 1,
+        "m" | "min" | "mins" | "minute" | "minutes" => 60,
+        "h" | "hr" | "hrs" | "hour" | "hours" => 60 * 60,
+        "d" | "day" | "days" => 24 * 60 * 60,
+        _ => return None,
+    };
+    amount.checked_mul(multiplier)
+}
+
+fn parse_utc_reset_delay(value: &str, now: DateTime<Utc>) -> Option<Duration> {
+    if !(value.contains("reset") || value.contains("resets")) {
+        return None;
+    }
+
+    let reset_time = find_time_of_day(value)?;
+    let reset_date = now.date_naive();
+    let reset_at = reset_date.and_time(reset_time);
+    let mut reset_at = DateTime::<Utc>::from_naive_utc_and_offset(reset_at, Utc);
+    if reset_at <= now {
+        reset_at += ChronoDuration::days(1);
+    }
+
+    (reset_at - now)
+        .to_std()
+        .ok()
+        .map(|delay| delay + AUTO_CONTINUE_RESET_BUFFER)
+}
+
+fn find_time_of_day(value: &str) -> Option<NaiveTime> {
+    let bytes = value.as_bytes();
+    let mut index = 0usize;
+    while index < bytes.len() {
+        if !bytes[index].is_ascii_digit() {
+            index += 1;
+            continue;
+        }
+
+        if let Some((time, _consumed)) = parse_time_at(&value[index..]) {
+            return Some(time);
+        }
+        index += 1;
+    }
+    None
+}
+
+fn parse_time_at(value: &str) -> Option<(NaiveTime, usize)> {
+    let bytes = value.as_bytes();
+    let mut index = 0usize;
+    let hour_start = index;
+    while index < bytes.len() && bytes[index].is_ascii_digit() && index - hour_start < 2 {
+        index += 1;
+    }
+    if index == hour_start {
+        return None;
+    }
+    let hour = value[hour_start..index].parse::<u32>().ok()?;
+    let mut minute = 0u32;
+
+    if bytes.get(index) == Some(&b':') {
+        index += 1;
+        let minute_start = index;
+        while index < bytes.len() && bytes[index].is_ascii_digit() && index - minute_start < 2 {
+            index += 1;
+        }
+        if index - minute_start != 2 {
+            return None;
+        }
+        minute = value[minute_start..index].parse::<u32>().ok()?;
+    }
+
+    while bytes.get(index).is_some_and(u8::is_ascii_whitespace) {
+        index += 1;
+    }
+
+    let suffix = value[index..].get(..2).unwrap_or_default();
+    let hour = match suffix {
+        "am" => {
+            index += 2;
+            if hour == 12 { 0 } else { hour }
+        }
+        "pm" => {
+            index += 2;
+            if hour == 12 { 12 } else { hour + 12 }
+        }
+        _ if value.contains("utc") && hour < 24 => hour,
+        _ => return None,
+    };
+
+    NaiveTime::from_hms_opt(hour, minute, 0).map(|time| (time, index))
+}
+
+fn bounded_auto_continue_delay(delay: Duration) -> Option<Duration> {
+    if delay > AUTO_CONTINUE_MAX_DELAY {
+        tracing::info!(
+            "Ignoring parsed session-limit reset delay {:?}; exceeds maximum {:?}",
+            delay,
+            AUTO_CONTINUE_MAX_DELAY
+        );
+        return None;
+    }
+    Some(delay)
+}
+
 fn success_exit_status() -> std::process::ExitStatus {
     #[cfg(unix)]
     {
@@ -1836,3 +2225,54 @@ fn success_exit_status() -> std::process::ExitStatus {
         ExitStatusExt::from_raw(0)
     }
 }
