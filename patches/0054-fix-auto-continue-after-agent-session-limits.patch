+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    fn utc_now(value: &str) -> DateTime<Utc> {
+        DateTime::parse_from_rfc3339(value)
+            .unwrap()
+            .with_timezone(&Utc)
+    }
+
+    #[test]
+    fn detects_claude_style_session_limit_reset_time() {
+        let history = vec![LogMsg::Stdout(
+            "You've hit your session limit · resets 6:30am (UTC)".to_string(),
+        )];
+        let plan = detect_session_limit_auto_continue(&history, utc_now("2026-06-21T06:00:00Z"))
+            .expect("expected auto-continue plan");
+
+        assert_eq!(plan.delay, Duration::from_secs(30 * 60 + 30));
+    }
+
+    #[test]
+    fn rolls_reset_time_to_tomorrow_when_today_has_passed() {
+        let history = vec![LogMsg::Stderr(
+            "Session limit reached. Resets 6:30am UTC.".to_string(),
+        )];
+        let plan = detect_session_limit_auto_continue(&history, utc_now("2026-06-21T06:31:00Z"))
+            .expect("expected auto-continue plan");
+
+        assert_eq!(plan.delay, Duration::from_secs(23 * 60 * 60 + 59 * 60 + 30));
+    }
+
+    #[test]
+    fn detects_relative_retry_delay() {
+        let history = vec![LogMsg::Stdout(
+            "Rate limit reached, try again in 1h 15m.".to_string(),
+        )];
+        let plan = detect_session_limit_auto_continue(&history, utc_now("2026-06-21T06:00:00Z"))
+            .expect("expected auto-continue plan");
+
+        assert_eq!(plan.delay, Duration::from_secs(75 * 60 + 30));
+    }
+
+    #[test]
+    fn ignores_limit_text_without_reset_time() {
+        let history = vec![LogMsg::Stdout("Session limit reached.".to_string())];
+
+        assert!(detect_session_limit_auto_continue(&history, Utc::now()).is_none());
+    }
+}
