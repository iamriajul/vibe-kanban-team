+    pub async fn current_git_identity(&self) -> Option<(String, String)> {
+        match self.get_login_status().await {
+            LoginStatus::LoggedIn { profile } => Self::git_identity_from_profile(&profile),
+            LoginStatus::LoggedOut => None,
+        }
+    }
+
+    pub(crate) fn git_identity_from_profile(
+        profile: &ProfileResponse,
+    ) -> Option<(String, String)> {
+        let email = profile.email.trim().to_string();
+        if email.is_empty() {
+            return None;
+        }
+
+        let name = profile
+            .providers
+            .iter()
+            .find_map(|provider| {
+                provider
+                    .display_name
+                    .as_ref()
+                    .map(|value| value.trim().to_string())
+                    .filter(|value| !value.is_empty())
+            })
+            .or_else(|| {
+                profile
+                    .username
+                    .as_ref()
+                    .map(|value| value.trim().to_string())
+                    .filter(|value| !value.is_empty())
+            })
+            .or_else(|| {
+                email
+                    .split('@')
+                    .next()
+                    .map(str::trim)
+                    .map(str::to_string)
+                    .filter(|value| !value.is_empty())
+            })?;
+
+        Some((name, email))
+    }
