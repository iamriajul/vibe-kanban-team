index 000000000..d8afd49cb
--- /dev/null
+++ b/packages/web-core/src/shared/notifications/AppWorkspaceAttentionNotifications.tsx
@@ -0,0 +1,117 @@
+import { useEffect, useRef } from 'react';
+import { SoundFile } from 'shared/types';
+import { useAuth } from '@/shared/hooks/auth/useAuth';
+import { useBrowserNotificationPreference } from '@/shared/hooks/useBrowserNotificationPreference';
+import { useUserSystem } from '@/shared/hooks/useUserSystem';
+import {
+  useWorkspaces,
+  type SidebarWorkspace,
+} from '@/shared/hooks/useWorkspaces';
+import {
+  getBrowserNotificationPermission,
+  showBrowserNotification,
+} from '@/shared/lib/browserNotifications';
+import { playSound } from '@/shared/lib/utils';
+
+interface AppWorkspaceAttentionNotificationsProps {
+  hostId?: string | null;
+}
+
+function workspaceNeedsAttention(workspace: SidebarWorkspace): boolean {
+  return (
+    workspace.hasPendingApproval === true ||
+    (workspace.hasUnseenActivity === true && workspace.isRunning !== true)
+  );
+}
+
+function getWorkspaceAttentionBody(workspace: SidebarWorkspace): string {
+  if (workspace.hasPendingApproval) {
+    return `${workspace.name} is waiting for approval.`;
+  }
+
+  return `${workspace.name} has new activity.`;
+}
+
+function getWorkspaceDeeplinkPath(
+  workspaceId: string,
+  hostId: string | null | undefined
+): string {
+  return hostId
+    ? `/hosts/${encodeURIComponent(hostId)}/workspaces/${encodeURIComponent(workspaceId)}`
+    : `/workspaces/${encodeURIComponent(workspaceId)}`;
+}
+
+export function AppWorkspaceAttentionNotifications({
+  hostId,
+}: AppWorkspaceAttentionNotificationsProps) {
+  const { isSignedIn, userId } = useAuth();
+  const { config } = useUserSystem();
+  const { enabled: browserNotificationsEnabled } =
+    useBrowserNotificationPreference(userId);
+  const { workspaces, isLoading } = useWorkspaces({
+    enabled: isSignedIn,
+    hostId,
+  });
+  const attentionByWorkspaceIdRef = useRef(new Map<string, boolean>());
+
+  useEffect(() => {
+    attentionByWorkspaceIdRef.current.clear();
+  }, [hostId, userId]);
+
+  useEffect(() => {
+    if (!isSignedIn || isLoading) {
+      return;
+    }
+
+    const seenWorkspaceIds = new Set(
+      workspaces.map((workspace) => workspace.id)
+    );
+    for (const workspaceId of attentionByWorkspaceIdRef.current.keys()) {
+      if (!seenWorkspaceIds.has(workspaceId)) {
+        attentionByWorkspaceIdRef.current.delete(workspaceId);
+      }
+    }
+
+    for (const workspace of workspaces) {
+      const needsAttention = workspaceNeedsAttention(workspace);
+      const previousNeedsAttention = attentionByWorkspaceIdRef.current.get(
+        workspace.id
+      );
+      attentionByWorkspaceIdRef.current.set(workspace.id, needsAttention);
+
+      if (previousNeedsAttention !== false || !needsAttention) {
+        continue;
+      }
+
+      if (
+        browserNotificationsEnabled &&
+        getBrowserNotificationPermission() === 'granted'
+      ) {
+        showBrowserNotification({
+          id: `workspace-attention:${workspace.id}`,
+          title: 'Workspace needs attention',
+          body: getWorkspaceAttentionBody(workspace),
+          deeplinkPath: getWorkspaceDeeplinkPath(workspace.id, hostId),
+        });
+      }
+
+      if (config?.notifications.sound_enabled !== false) {
+        const soundFile =
+          config?.notifications.sound_file ?? SoundFile.ABSTRACT_SOUND1;
+        void playSound(`/api/sounds/${soundFile}`).catch((error) => {
+          console.warn('Failed to play workspace attention sound:', error);
+        });
+      }
+    }
+  }, [
+    browserNotificationsEnabled,
+    config?.notifications.sound_enabled,
+    config?.notifications.sound_file,
+    hostId,
+    isLoading,
+    isSignedIn,
+    workspaces,
+  ]);
+
+  return null;
+}
