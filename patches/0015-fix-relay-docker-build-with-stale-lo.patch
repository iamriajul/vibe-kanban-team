From b88f67e9c3e71761564f5e1f96e9d42048034d24 Mon Sep 17 00:00:00 2001
From: Riajul Islam <riajul@kahf.co>
Date: Tue, 14 Apr 2026 06:27:05 +0000
Subject: [PATCH 15/17] downstream:
 0015-fix-relay-docker-build-with-stale-lockfile


diff --git a/crates/relay-tunnel/Dockerfile b/crates/relay-tunnel/Dockerfile
index 523132b67..e56f409f5 100644
--- a/crates/relay-tunnel/Dockerfile
+++ b/crates/relay-tunnel/Dockerfile
@@ -50,7 +50,7 @@ RUN mkdir -p /app/bin
 RUN --mount=type=cache,id=cargo-registry,target=/usr/local/cargo/registry \
     --mount=type=cache,id=cargo-git,target=/usr/local/cargo/git \
     --mount=type=cache,id=relay-target,target=/app/target \
-    cargo build --locked --release --manifest-path crates/relay-tunnel/Cargo.toml \
+    cargo build --release --manifest-path crates/relay-tunnel/Cargo.toml \
  && cp /app/target/release/relay-server /app/bin/relay-server
 
 FROM debian:bookworm-slim
