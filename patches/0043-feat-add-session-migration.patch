+            disabled={!sourceSession || !executorConfig || isMigrating}
+          >
+            {isMigrating ? 'Migrating...' : 'Migrate'}
+          </Button>
+        </DialogFooter>
+      </DialogContent>
+    </Dialog>
+  );
+}
