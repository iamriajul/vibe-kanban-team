+            transcript as handoff context.
+          </DialogDescription>
+        </DialogHeader>
+        <div className="space-y-4 py-2">
+          <div className="grid gap-2">
+            <label htmlFor="migration-agent" className="text-sm font-medium">
+              Target executor
+            </label>
+            <Select
+              value={effectiveExecutor ?? undefined}
