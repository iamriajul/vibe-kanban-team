+function buildSessionMigrationPrompt({
+  sourceSession,
+  targetExecutor,
+  entries,
+}: {
+  sourceSession: Session;
+  targetExecutor: BaseCodingAgent;
+  entries: PatchTypeWithKey[];
+}) {
+  const transcriptEntries = entries
+    .filter((entry) => entry.type === 'NORMALIZED_ENTRY')
+    .map((entry) => entry.content)
+    .filter((entry) =>
+      [
+        'user_message',
+        'assistant_message',
+        'system_message',
+        'user_feedback',
+        'user_answered_questions',
+      ].includes(entry.entry_type.type)
+    )
+    .slice(-MIGRATION_TRANSCRIPT_ENTRY_LIMIT);
+
+  const transcript = transcriptEntries
+    .map((entry) => {
+      const role =
+        entry.entry_type.type === 'assistant_message'
+          ? 'Assistant'
+          : entry.entry_type.type === 'system_message'
+            ? 'System'
+            : 'User';
+      return `### ${role}\n${entry.content.trim()}`;
+    })
+    .join('\n\n')
+    .slice(-MIGRATION_TRANSCRIPT_CHAR_LIMIT);
+
+  return [
+    `We are migrating this Vibe Kanban session from ${sourceSession.executor ?? 'the previous executor'} to ${targetExecutor}.`,
+    '',
+    'Use the context below as the prior conversation and continue the same engineering task in this workspace. Inspect the repository before changing files. Preserve any existing working-tree changes unless I explicitly ask otherwise.',
+    '',
+    `Source session ID: ${sourceSession.id}`,
+    sourceSession.name ? `Source session name: ${sourceSession.name}` : null,
+    '',
+    'Migrated transcript:',
+    transcript || '(No transcript entries were available in the current view.)',
+  ]
+    .filter((line): line is string => line !== null)
+    .join('\n');
+}
