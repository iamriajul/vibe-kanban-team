+fn apply_antigravity_overrides(
+    builder: CommandBuilder,
+    overrides: &CmdOverrides,
+) -> Result<CommandBuilder, CommandBuildError> {
+    let builder = if let Some(base) = &overrides.base_command_override {
+        builder.override_base(base.clone())
+    } else {
+        builder
+    };
+
+    let Some(additional_params) = &overrides.additional_params else {
+        return Ok(builder);
+    };
+
+    let filtered = filter_antigravity_additional_params(additional_params)?;
+    Ok(builder.extend_params(filtered))
+}
+
+fn filter_antigravity_additional_params(
+    additional_params: &[String],
+) -> Result<Vec<String>, CommandBuildError> {
+    let joined = additional_params.join(" ");
+    if joined.trim().is_empty() {
+        return Ok(Vec::new());
+    }
+
+    let params = shlex::split(&joined)
+        .ok_or_else(|| CommandBuildError::InvalidShellParams(joined.clone()))?;
+    let mut filtered = Vec::with_capacity(params.len());
+    let mut index = 0;
+
+    while index < params.len() {
+        let param = &params[index];
+        if ANTIGRAVITY_BLOCKED_STANDALONE_ARGS.contains(&param.as_str()) {
+            index += 1;
+            continue;
+        }
+        if ANTIGRAVITY_BLOCKED_VALUE_ARGS.contains(&param.as_str()) {
+            index += 1;
+            if index < params.len() {
+                index += 1;
+            }
+            continue;
+        }
+
+        filtered.push(param.clone());
+        index += 1;
+    }
+
+    Ok(filtered)
+}
+
+fn antigravity_model_error(model: &str, available: &[String]) -> Option<String> {
+    if model.trim().is_empty()
+        || available.is_empty()
+        || available.iter().any(|available| available == model)
+    {
+        return None;
+    }
+
+    Some(format!(
+        "Antigravity model {model:?} is not available from `agy models`; pick one of: {}",
+        available.join(", ")
+    ))
+}
