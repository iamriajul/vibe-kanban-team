+async fn validate_antigravity_model(
+    cmd: &CmdOverrides,
+    current_dir: &Path,
+    model: Option<&str>,
+) -> Result<(), ExecutorError> {
+    let Some(model) = model.map(str::trim).filter(|model| !model.is_empty()) else {
+        return Ok(());
+    };
+    let Some(catalog) = discover_antigravity_model_catalog(cmd, current_dir).await else {
+        return Ok(());
+    };
+    antigravity_model_error(model, &catalog)
+        .map(|message| Err(ExecutorError::Io(std::io::Error::other(message))))
+        .unwrap_or(Ok(()))
+}
+
