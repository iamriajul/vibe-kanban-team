From 0f4c27d7650f56b99b46e85c1ac831f68e41c970 Mon Sep 17 00:00:00 2001
From: Codex <codex@openai.com>
Date: Wed, 11 Mar 2026 09:07:00 +0000
Subject: [PATCH] fix(relay): build relay image without locked crate-local lockfile

The upstream relay-tunnel crate is built from
`crates/relay-tunnel/Cargo.toml`. Its crate-local lockfile may need
regeneration, so `cargo build --locked` can fail in CI and block relay
image releases.

Allow Cargo to refresh that nested lockfile during the image build.
---
 crates/relay-tunnel/Dockerfile | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/crates/relay-tunnel/Dockerfile b/crates/relay-tunnel/Dockerfile
index 5462ad773..9a1f91c12 100644
--- a/crates/relay-tunnel/Dockerfile
+++ b/crates/relay-tunnel/Dockerfile
@@ -38,5 +38,5 @@ RUN mkdir -p /app/bin
 RUN --mount=type=cache,id=cargo-registry,target=/usr/local/cargo/registry \
     --mount=type=cache,id=cargo-git,target=/usr/local/cargo/git \
     --mount=type=cache,id=relay-target,target=/app/target \
-    cargo build --locked --release --manifest-path crates/relay-tunnel/Cargo.toml \
+    cargo build --release --manifest-path crates/relay-tunnel/Cargo.toml \
  && cp /app/target/release/relay-server /app/bin/relay-server
-- 
2.50.1
