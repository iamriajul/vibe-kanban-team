From d86ff867cb5c2893ab360a1080dada83963d681a Mon Sep 17 00:00:00 2001
From: Riajul Islam <opensource@example.com>
Date: Thu, 19 Mar 2026 00:01:21 +0000
Subject: [PATCH] feat: store workspace owner locally and use for creator
 filter

Add ownerUserId to SidebarWorkspace and WorkspaceWithStatus types.
Build the creator filter ownerByLocalId map from local workspace stream
data (owner_user_id stored in local SQLite) instead of making
per-workspace API calls to the remote server. Falls back to remote
workspace data for older workspaces created before this field existed.
---
 .../workspaces/WorkspacesSidebarContainer.tsx | 126 ++----------------
 .../src/shared/hooks/useWorkspaces.ts         |   2 +
 shared/types.ts                               |   4 +-
 3 files changed, 15 insertions(+), 117 deletions(-)

diff --git a/packages/web-core/src/pages/workspaces/WorkspacesSidebarContainer.tsx b/packages/web-core/src/pages/workspaces/WorkspacesSidebarContainer.tsx
index 8cdea73e0..0700097a6 100644
--- a/packages/web-core/src/pages/workspaces/WorkspacesSidebarContainer.tsx
+++ b/packages/web-core/src/pages/workspaces/WorkspacesSidebarContainer.tsx
@@ -7,11 +7,9 @@ import { useAllOrganizationProjects } from '@/shared/hooks/useAllOrganizationPro
 import { useUserOrganizations } from '@/shared/hooks/useUserOrganizations';
 import { useOrganizationSelection } from '@/shared/hooks/useOrganizationSelection';
 import { useAuth } from '@/shared/hooks/auth/useAuth';
-import { makeLocalApiRequest } from '@/shared/lib/localApiTransport';
 import {
   MemberRole as MemberRoleEnum,
   ScratchType,
-  type ApiResponse,
   type DraftWorkspaceData,
 } from 'shared/types';
 import type { Project } from 'shared/remote-types';
@@ -353,125 +351,23 @@ export function WorkspacesSidebarContainer({
     return map;
   }, [remoteWorkspaces]);
 
-  // Map local workspace ID -> creator (remote owner user ID) when available
-  const remoteOwnerByLocalId = useMemo(() => {
+  // Build owner map from local workspace stream data (owner_user_id stored in local SQLite).
+  // Falls back to remote workspace data for workspaces created before this field existed.
+  const ownerByLocalId = useMemo(() => {
     const map = new Map<string, string>();
-    for (const rw of remoteWorkspaces) {
-      if (rw.local_workspace_id) {
-        map.set(rw.local_workspace_id, rw.owner_user_id);
+    for (const ws of [...activeWorkspaces, ...archivedWorkspaces]) {
+      if (ws.ownerUserId) {
+        map.set(ws.id, ws.ownerUserId);
       }
     }
-    return map;
-  }, [remoteWorkspaces]);
-
-  const [resolvedOwnerByLocalId, setResolvedOwnerByLocalId] = useState<
-    Record<string, string>
-  >({});
-  const [ownerLookupAttemptedIds, setOwnerLookupAttemptedIds] = useState<
-    Record<string, true>
-  >({});
-
-  const allWorkspaceIds = useMemo(
-    () =>
-      Array.from(
-        new Set([...activeWorkspaces, ...archivedWorkspaces].map((ws) => ws.id))
-      ),
-    [activeWorkspaces, archivedWorkspaces]
-  );
-
-  useEffect(() => {
-    if (!currentUserId || allWorkspaceIds.length === 0) {
-      return;
-    }
-
-    const idsToResolve = allWorkspaceIds.filter(
-      (workspaceId) =>
-        !remoteOwnerByLocalId.has(workspaceId) &&
-        !resolvedOwnerByLocalId[workspaceId] &&
-        !ownerLookupAttemptedIds[workspaceId]
-    );
-
-    if (idsToResolve.length === 0) {
-      return;
-    }
-
-    setOwnerLookupAttemptedIds((prev) => ({
-      ...prev,
-      ...Object.fromEntries(idsToResolve.map((id) => [id, true as const])),
-    }));
-
-    let cancelled = false;
-
-    void (async () => {
-      const ownerEntries = await Promise.all(
-        idsToResolve.map(async (workspaceId) => {
-          try {
-            const response = await makeLocalApiRequest(
-              `/api/remote/workspaces/by-local-id/${workspaceId}`
-            );
-            if (!response.ok) {
-              return null;
-            }
-
-            const payload = (await response.json()) as ApiResponse<{
-              owner_user_id?: string | null;
-            }>;
-
-            const ownerUserId = payload.data?.owner_user_id ?? null;
-            if (!ownerUserId) {
-              return null;
-            }
-
-            return { workspaceId, ownerUserId };
-          } catch {
-            return null;
-          }
-        })
-      );
-
-      if (cancelled) {
-        return;
-      }
-
-      const resolvedEntries = ownerEntries.filter(
-        (entry): entry is { workspaceId: string; ownerUserId: string } =>
-          entry !== null
-      );
-
-      if (resolvedEntries.length === 0) {
-        return;
-      }
-
-      setResolvedOwnerByLocalId((prev) => ({
-        ...prev,
-        ...Object.fromEntries(
-          resolvedEntries.map((entry) => [entry.workspaceId, entry.ownerUserId])
-        ),
-      }));
-    })();
-
-    return () => {
-      cancelled = true;
-    };
-  }, [
-    allWorkspaceIds,
-    currentUserId,
-    ownerLookupAttemptedIds,
-    remoteOwnerByLocalId,
-    resolvedOwnerByLocalId,
-  ]);
-
-  const ownerByLocalId = useMemo(() => {
-    const map = new Map(remoteOwnerByLocalId);
-    for (const [workspaceId, ownerUserId] of Object.entries(
-      resolvedOwnerByLocalId
-    )) {
-      if (!map.has(workspaceId)) {
-        map.set(workspaceId, ownerUserId);
+    // Remote data as fallback for older workspaces without local owner_user_id
+    for (const rw of remoteWorkspaces) {
+      if (rw.local_workspace_id && !map.has(rw.local_workspace_id)) {
+        map.set(rw.local_workspace_id, rw.owner_user_id);
       }
     }
     return map;
-  }, [remoteOwnerByLocalId, resolvedOwnerByLocalId]);
+  }, [activeWorkspaces, archivedWorkspaces, remoteWorkspaces]);
 
   const creatorFilterOptions = useMemo(() => {
     const ownerIds = new Set(ownerByLocalId.values());
diff --git a/packages/web-core/src/shared/hooks/useWorkspaces.ts b/packages/web-core/src/shared/hooks/useWorkspaces.ts
index aa5933927..c694bb403 100644
--- a/packages/web-core/src/shared/hooks/useWorkspaces.ts
+++ b/packages/web-core/src/shared/hooks/useWorkspaces.ts
@@ -32,6 +32,7 @@ export interface SidebarWorkspace {
   prStatus?: 'open' | 'merged' | 'closed' | 'unknown';
   prNumber?: number;
   prUrl?: string;
+  ownerUserId?: string | null;
 }
 
 // Keep the old export name for backwards compatibility
@@ -84,6 +85,7 @@ function toSidebarWorkspace(
     prNumber:
       summary?.pr_number != null ? Number(summary.pr_number) : undefined,
     prUrl: summary?.pr_url ?? undefined,
+    ownerUserId: ws.owner_user_id,
   };
 }
 
diff --git a/shared/types.ts b/shared/types.ts
index 88ce288a3..35732107d 100644
--- a/shared/types.ts
+++ b/shared/types.ts
@@ -144,9 +144,9 @@ export type Image = { id: string, file_path: string, original_name: string, mime
 
 export type CreateImage = { file_path: string, original_name: string, mime_type: string | null, size_bytes: bigint, hash: string, };
 
-export type Workspace = { id: string, task_id: string | null, container_ref: string | null, branch: string, setup_completed_at: string | null, created_at: string, updated_at: string, archived: boolean, pinned: boolean, name: string | null, worktree_deleted: boolean, };
+export type Workspace = { id: string, task_id: string | null, container_ref: string | null, branch: string, setup_completed_at: string | null, created_at: string, updated_at: string, archived: boolean, pinned: boolean, name: string | null, worktree_deleted: boolean, owner_user_id: string | null, };
 
-export type WorkspaceWithStatus = { is_running: boolean, is_errored: boolean, id: string, task_id: string | null, container_ref: string | null, branch: string, setup_completed_at: string | null, created_at: string, updated_at: string, archived: boolean, pinned: boolean, name: string | null, worktree_deleted: boolean, };
+export type WorkspaceWithStatus = { is_running: boolean, is_errored: boolean, id: string, task_id: string | null, container_ref: string | null, branch: string, setup_completed_at: string | null, created_at: string, updated_at: string, archived: boolean, pinned: boolean, name: string | null, worktree_deleted: boolean, owner_user_id: string | null, };
 
 export type Session = { id: string, workspace_id: string, executor: string | null, agent_working_dir: string | null, created_at: string, updated_at: string, };
 
