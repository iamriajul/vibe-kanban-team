index a0a3f3c39..144c749c1 100644
--- a/crates/server/src/routes/workspaces/mod.rs
+++ b/crates/server/src/routes/workspaces/mod.rs
@@ -13,13 +13,34 @@ pub mod repos;
 pub mod streams;
