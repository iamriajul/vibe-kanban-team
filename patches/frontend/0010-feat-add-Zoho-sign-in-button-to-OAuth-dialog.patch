 .../web-core/src/i18n/locales/fr/common.json  |  1 +
 .../web-core/src/i18n/locales/ja/common.json  |  1 +
 .../web-core/src/i18n/locales/ko/common.json  |  1 +
 .../src/i18n/locales/zh-Hans/common.json      |  1 +
 .../src/i18n/locales/zh-Hant/common.json      |  1 +
 .../src/shared/dialogs/global/OAuthDialog.tsx |  7 +++++-
 10 files changed, 43 insertions(+), 2 deletions(-)
 create mode 100644 packages/ui/src/components/ZohoLogo.tsx

diff --git a/packages/ui/src/components/OAuthButtons.tsx b/packages/ui/src/components/OAuthButtons.tsx
index 954850895..1f4c6ed4f 100644
--- a/packages/ui/src/components/OAuthButtons.tsx
+++ b/packages/ui/src/components/OAuthButtons.tsx
@@ -3,8 +3,9 @@ import { SpinnerIcon } from '@phosphor-icons/react';
 import { GitHubDark } from 'developer-icons';
 import { useTranslation } from 'react-i18next';
 import { GoogleLogo } from './GoogleLogo';
+import { ZohoLogo } from './ZohoLogo';
 
-export type OAuthProvider = 'github' | 'google';
+export type OAuthProvider = 'github' | 'google' | 'zoho';
 
 interface OAuthSignInButtonProps {
   provider: OAuthProvider;
@@ -24,6 +25,10 @@ const providerConfig = {
     i18nKey: 'oauth.continueWithGoogle' as const,
     icon: () => <GoogleLogo className="size-5" />,
   },
+  zoho: {
+    i18nKey: 'oauth.continueWithZoho' as const,
+    icon: () => <ZohoLogo className="size-5" />,
+  },
 };
 
 export function OAuthSignInButton({
diff --git a/packages/ui/src/components/ZohoLogo.tsx b/packages/ui/src/components/ZohoLogo.tsx
new file mode 100644
index 000000000..8409feddd
--- /dev/null
+++ b/packages/ui/src/components/ZohoLogo.tsx
@@ -0,0 +1,24 @@
+import { cn } from '../lib/cn';
+
+interface ZohoLogoProps {
+  className?: string;
+}
+
+/**
+ * Zoho's "Z" logo mark in brand red (#E42527).
+ */
+export function ZohoLogo({ className }: ZohoLogoProps) {
+  return (
+    <svg
+      className={cn('size-5', className)}
+      viewBox="0 0 48 48"
+      xmlns="http://www.w3.org/2000/svg"
+      aria-hidden="true"
+    >
+      <path
+        fill="#E42527"
+        d="M4 8h30.4L4 36.8V40h40v-8H14.4L44 3.6V0H4v8z"
+      />
+    </svg>
+  );
+}
