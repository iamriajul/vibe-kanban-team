{$DOMAIN:localhost} {
	encode zstd gzip

	# Relay/tunnel support is optional. These routes return 502 unless the
	# relay profile is running: docker compose --profile relay up -d
	handle /v1/relay* {
		reverse_proxy relay-server:8082
	}

	handle /relay/h* {
		reverse_proxy relay-server:8082
	}

	handle {
		reverse_proxy remote-server:8081
	}
}
